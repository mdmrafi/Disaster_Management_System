# Copy to `.env` (or `.env.production`) and adjust for your environment.
# On Render this value is injected at build time as a static-site env var.

# Local dev: leave unset so the client uses '/api' and Vite's proxy
# forwards to http://localhost:8080.

# Production / Render example:
# VITE_API_URL=https://disaster-api.onrender.com/api