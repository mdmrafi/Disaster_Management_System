# =========================================================
# Disaster Management API — example configuration
# Copy this file to `application.properties` and fill in
# your local values. The real `application.properties` is
# gitignored because it contains secrets.
# =========================================================

spring.application.name=disaster-management

# --- Datasource (MySQL) -----------------------------------
spring.datasource.url=jdbc:mysql://localhost:3306/disaster_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=YOUR_MYSQL_USERNAME
spring.datasource.password=YOUR_MYSQL_PASSWORD

# --- JPA / Hibernate --------------------------------------
# We manage schema and triggers via the SQL files in /db,
# so ddl-auto is set to "none" to avoid Hibernate fighting
# with our hand-written DDL.
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# --- Server -----------------------------------------------
server.port=8080
server.error.include-message=always
server.error.include-binding-errors=always

# --- Auth (JWT, HS256) -----------------------------------
# The secret must be 64 random bytes (base64-encoded).
# Generate one with:
#   openssl rand -base64 64
# Rotate this before any non-dev deployment.
security.jwt.secret=REPLACE_WITH_BASE64_64BYTE_SECRET
security.jwt.expiration-ms=86400000
