# =========================================================
# Disaster Management API — example configuration
# Copy this file to `application.properties` and fill in
# your local values. The real `application.properties` is
# gitignored because it contains secrets.
# =========================================================

spring.application.name=disaster-management

# --- Datasource (MySQL) -----------------------------------
# All values can be overridden via environment variables, which is how
# Render injects the database connection for `disaster-api` (see render.yaml).
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:mysql://localhost:3306/disaster_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:YOUR_MYSQL_USERNAME}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:YOUR_MYSQL_PASSWORD}

# --- JPA / Hibernate --------------------------------------
# We manage schema and triggers via the SQL files in /db,
# so ddl-auto is set to "none" to avoid Hibernate fighting
# with our hand-written DDL.
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# --- Server -----------------------------------------------
# Render sets $PORT automatically; we honor it when present so the
# Spring container can bind to Render's assigned port.
server.port=${PORT:8080}
server.error.include-message=always
server.error.include-binding-errors=always

# --- Auth (JWT, HS256) -----------------------------------
# The secret must be 64 random bytes (base64-encoded).
# Generate one with:  openssl rand -base64 64
# On Render this is provided via the SECURITY_JWT_SECRET env var.
security.jwt.secret=${SECURITY_JWT_SECRET:REPLACE_WITH_BASE64_64BYTE_SECRET}
security.jwt.expiration-ms=${SECURITY_JWT_EXPIRATION_MS:86400000}

# --- CORS -------------------------------------------------
# Comma-separated list of allowed origins for the SPA.
# Local dev defaults are appended for convenience.
app.cors.allowed-origins=${APP_CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost:4173}
